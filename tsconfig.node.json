{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": true,
    "noEmit": true,
    // Lets the *.check.ts self-checks run under `node --experimental-strip-types`,
    // which requires relative imports to carry their .ts extension.
    "allowImportingTsExtensions": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["src/types/*"]
    }
  },
  "include": ["electron", "electron.vite.config.ts", "src/types"]
}
